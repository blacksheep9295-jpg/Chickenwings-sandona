<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chicken Wings Sandoná - Pedidos</title>
    <style>
        :root {
            --fire-orange: #ff6a00;
            --fire-yellow: #ffb400;
            --dark-bg: #0a0a0a;
            --card-bg: #1a1a1a;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--dark-bg);
            color: white;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        header {
            width: 100%;
            text-align: center;
            padding: 20px 0;
            background: linear-gradient(180deg, #000 0%, transparent 100%);
        }

        .logo {
            max-width: 200px;
            height: auto;
            filter: drop-shadow(0 0 10px var(--fire-orange));
        }

        .container {
            width: 90%;
            max-width: 500px;
            padding-bottom: 100px;
        }

        .promo-badge {
            background: linear-gradient(45deg, var(--fire-orange), var(--fire-yellow));
            color: black;
            font-weight: bold;
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .product-card {
            background: var(--card-bg);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #333;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        .price {
            color: var(--fire-yellow);
            font-size: 1.5rem;
            font-weight: bold;
            display: block;
            margin: 10px 0;
        }

        h3 { margin-top: 0; color: var(--fire-orange); }

        .flavor-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }

        .flavor-option {
            background: #333;
            padding: 10px;
            border-radius: 5px;
            font-size: 0.8rem;
            cursor: pointer;
            text-align: center;
            border: 2px solid transparent;
        }

        .flavor-option.selected {
            border-color: var(--fire-orange);
            background: #444;
        }

        .footer-info {
            font-size: 0.8rem;
            color: #888;
            text-align: center;
            margin-top: 10px;
        }

        .btn-order {
            position: fixed;
            bottom: 20px;
            width: 90%;
            max-width: 450px;
            background: #25d366;
            color: white;
            border: none;
            padding: 18px;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
            z-index: 100;
        }

        input[type="text"] {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border-radius: 8px;
            border: 1px solid #444;
            background: #222;
            color: white;
            box-sizing: border-box;
        }
    </style>
</head>
<body>

<header>
    <img src="https://i.ibb.co/LdYp6N6/logo-chicken-wings.png" alt="Chicken Wings Sandoná" class="logo">
    <h1 style="font-size: 1.2rem; margin: 10px 0;">CHICKEN WINGS SANDONÁ</h1>
    <p style="font-size: 0.8rem; color: #ffb400;">📍 San Donna, Nariño | Solo Domicilios</p>
</header>

<div class="container">
    <div class="promo-badge">
        🔥 FIN DE SEMANA: Todos los pedidos incluyen papitas fritas y salsa Ranch. ¡DOMICILIO INCLUIDO!
    </div>

    <div class="product-card">
        <h3>Porción Individual</h3>
        <span class="price">$17.000</span>
        <p style="font-size: 0.9rem;">6 Alitas crocantes + Papas + Ranch</p>
        <button class="flavor-option" onclick="seleccionarCombo('Individual', 17000)" id="btn-ind">Seleccionar</button>
    </div>

    <div class="product-card">
        <h3>SUPER PROMO 🚀</h3>
        <span class="price">$30.000</span>
        <p style="font-size: 0.9rem;">12 Alitas crocantes + Papas + Ranch</p>
        <button class="flavor-option" onclick="seleccionarCombo('Promoción 12', 30000)" id="btn-promo">Seleccionar</button>
    </div>

    <div class="product-card">
        <h3>Escoge tus Sabores:</h3>
        <div class="flavor-grid">
            <div class="flavor-option" onclick="toggleFlavor(this)">BBQ</div>
            <div class="flavor-option" onclick="toggleFlavor(this)">Búfalo</div>
            <div class="flavor-option" onclick="toggleFlavor(this)">Miel Mostaza</div>
            <div class="flavor-option" onclick="toggleFlavor(this)">Limón Pimienta</div>
        </div>
    </div>

    <div class="product-card">
        <h3>Datos de Entrega:</h3>
        <input type="text" id="nombre" placeholder="¿A nombre de quién?">
        <input type="text" id="direccion" placeholder="Dirección en Sandoná">
    </div>

    <div class="footer-info">
        *Los pedidos se procesan de inmediato vía WhatsApp.
    </div>
</div>

<button class="btn-order" onclick="enviarPedido()">PEDIR POR WHATSAPP 🍗</button>

<script>
    let comboSeleccionado = "";
    let precioSeleccionado = 0;
    let sabores = [];

    function seleccionarCombo(nombre, precio) {
        comboSeleccionado = nombre;
        precioSeleccionado = precio;
        document.getElementById('btn-ind').style.background = nombre === 'Individual' ? '#ff6a00' : '#333';
        document.getElementById('btn-promo').style.background = nombre === 'Promoción 12' ? '#ff6a00' : '#333';
    }

    function toggleFlavor(element) {
        const sabor = element.innerText;
        if (sabores.includes(sabor)) {
            sabores = sabores.filter(s => s !== sabor);
            element.classList.remove('selected');
        } else {
            sabores.push(sabor);
            element.classList.add('selected');
        }
    }

    function enviarPedido() {
        const nombre = document.getElementById('nombre').value;
        const direccion = document.getElementById('direccion').value;

        if (!comboSeleccionado) return alert("Por favor elige tu porción.");
        if (sabores.length === 0) return alert("Elige al menos un sabor.");
        if (!nombre || !direccion) return alert("Faltan datos de entrega.");

        const mensaje = `*PEDIDO CHICKEN WINGS SANDONÁ*%0A` +
                        `-------------------------------%0A` +
                        `*Cliente:* ${nombre}%0A` +
                        `*Producto:* ${comboSeleccionado}%0A` +
                        `*Sabores:* ${sabores.join(', ')}%0A` +
                        `*Total:* $${precioSeleccionado}%0A` +
                        `*Dirección:* ${direccion}%0A` +
                        `-------------------------------%0A` +
                        `_Incluye papas, ranch y domicilio._`;

        window.open(`https://wa.me/573137462516?text=${mensaje}`, '_blank');
    }
</script>

</body>
</html>
